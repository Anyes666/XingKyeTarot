/**
 * 星澜小纸条素材池（30 条）
 *
 * 每条 12–28 字，适合单独显示。温柔、克制、不绝对化。
 */
export const PAPER_NOTES: string[] = [
  '今天可以先不急着证明自己。',
  '你可以慢一点，慢不代表落后。',
  '先把呼吸还给自己。',
  '你的感受，不需要被批准才算数。',
  '不知道怎么说，也可以从一个词开始。',
  '星钥不是答案，只是一点光。',
  '你不用把自己整理得很完美。',
  '先别催自己，月光也会慢慢落下来。',
  '有些难过很小声，也值得被听见。',
  '今天先不问结果，问问自己还好吗。',
  '累的时候，可以先不前进。',
  '你不需要马上好起来。',
  '先把心事放轻一点。',
  '有些路不是走错了，只是还没走完。',
  '今天的你，已经很努力了。',
  '不用急着给每一件事找答案。',
  '安静也是一种力量。',
  '你可以暂时什么都不做。',
  '被接住的感觉，从这里开始。',
  '你不必一直坚强。',
  '难过是可以被看见的。',
  '先停下来，听听自己。',
  '月光不催人，它只是照着。',
  '你不是一个人在这里。',
  '今天的温柔，先留给自己。',
  '有些话，不需要说得太清楚。',
  '先允许自己不好。',
  '此刻的你，已经足够了。',
  '慢慢说，星澜在听。',
  '今夜先不问未来。'
];

export function getRandomPaperNote(): string {
  const idx: number = Math.floor(Math.random() * PAPER_NOTES.length);
  return PAPER_NOTES[idx];
}
