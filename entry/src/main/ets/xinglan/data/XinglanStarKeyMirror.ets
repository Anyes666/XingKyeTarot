import {
  XinglanMirrorTopic, XinglanStarKeyMirror,
  XinglanQuestionOption, XinglanInteractionFlowId,
  XinglanEmotionTag, XinglanTopicTag
} from '../types/XinglanTypes';

let mirrorIdCounter: number = 0;

function makeOpt(
  id: string, label: string, userText: string, lines: string[],
  clearAfterSelect: boolean
): XinglanQuestionOption {
  return {
    id, label, userText,
    replyLines: lines, nextOptions: [],
    nextFlowId: XinglanInteractionFlowId.NONE, clearAfterSelect,
    emotionTag: XinglanEmotionTag.ANY, topicTag: XinglanTopicTag.ANY
  };
}

function makeMirror(
  topic: XinglanMirrorTopic,
  sym: string[], ref: string[],
  question: string, action: string
): XinglanStarKeyMirror {
  mirrorIdCounter += 1;
  return {
    id: `mirror_${mirrorIdCounter}`, topic,
    symbolLines: sym, reflectionLines: ref,
    softQuestion: question, tinyAction: action,
    followUpOptions: [
      makeOpt('m_again', '再照一次', '再照一次',
        ['好，那我们换一个方向再照照。', '你想让它照一下哪里？'], true),
      makeOpt('m_save', '收进回声', '收进回声',
        ['好，星澜帮你把这一刻收好了。', '以后当你需要的时候，可以再回来看看。'], true),
      makeOpt('m_back', '回到聊天', '回到聊天',
        ['好，星澜在这里。', '你想说什么都可以。'], true)
    ],
    createdAt: 0
  };
}

