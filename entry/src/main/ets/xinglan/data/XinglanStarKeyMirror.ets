// ═══ 主题索引 ═══
const ALL_MIRRORS_BY_TOPIC: Record<string, XinglanStarKeyMirror[]> = {
  'EMOTION': EMOTION_MIRRORS,
  'RELATION': RELATION_MIRRORS,
  'CHOICE': CHOICE_MIRRORS,
  'TIRED': TIRED_MIRRORS,
  'TONIGHT': TONIGHT_MIRRORS
};

export function getRandomMirror(topic: XinglanMirrorTopic): XinglanStarKeyMirror {
  const key: string = topic.valueOf() as string;
  const list: XinglanStarKeyMirror[] = ALL_MIRRORS_BY_TOPIC[key];
  if (!list || list.length === 0) { return EMOTION_MIRRORS[0]; }
  const idx: number = Math.floor(Math.random() * list.length);
  const m: XinglanStarKeyMirror = list[idx];
  m.createdAt = Date.now();
  return m;
}

