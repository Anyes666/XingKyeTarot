  private navigateBack(): void {
    try {
      router.back();
    } catch (_err) {
      try {
        router.replaceUrl({ url: Routes.SETTINGS });
      } catch (_err2) {
        // ignore
      }
    }
  }

  /**
   * 渲染单个说明卡片
   */
  @Builder
  buildSectionCard(icon: string, title: string, body: string): void {
    Column() {
      // 图标
      Text(icon)
        .fontSize(28)
        .fontColor('#E8B83D')
        .margin({ bottom: 12 })

      // 标题
      Text(title)
        .fontSize(Theme.FONT_SUBTITLE)
        .fontColor(Theme.GOLD_LIGHT)
        .fontWeight(FontWeight.Bold)
        .width('100%')
        .textAlign(TextAlign.Start)
        .margin({ bottom: 12 })

      // 正文
      Text(body)
        .fontSize(Theme.FONT_BODY)
        .fontColor(Theme.TEXT_PRIMARY_LIGHT)
        .lineHeight(24)
        .width('100%')
        .textAlign(TextAlign.Start)
    }
    .width('100%')
    .padding({ top: Theme.STARKEY_CARD_PADDING_V, bottom: Theme.STARKEY_CARD_PADDING_V, left: Theme.STARKEY_CARD_PADDING_H, right: Theme.STARKEY_CARD_PADDING_H })
    .backgroundColor(Theme.STARKEY_CARD_BG)
    .borderRadius(Theme.STARKEY_CARD_RADIUS)
    .border({ width: 1, color: Theme.STARKEY_CARD_BORDER })
    .shadow(Theme.SHADOW_CARD_SUBTLE)
    .margin({ bottom: Theme.SPACE_MD })
  }

  build() {
    Stack() {
      // 沉浸式深空背景
      Column()
        .width('100%')
        .height('100%')
        .linearGradient({
          direction: GradientDirection.Bottom,
          colors: [
            [Theme.BG_DEEP_SPACE, 0.0],
            [Theme.BG_DEEP_INDIGO, 0.55],
            [Theme.BG_DEEP_INDIGO, 1.0]
          ]
        })

      // 主内容
      Column() {
        // 顶部安全区 + 返回按钮
        Row() {
          AppBackButton({ fallbackUrl: Routes.SETTINGS })
        }
        .width('100%')
        .height(56)
        .padding({ top: Theme.SAFE_TOP, left: Theme.SPACE_SM, right: Theme.SPACE_SM })
        .alignItems(VerticalAlign.Center)

        // 标题
        Text('使用说明')
          .fontSize(Theme.FONT_HEADLINE)
          .fontColor(Theme.GOLD_LIGHT)
          .fontWeight(FontWeight.Bold)
          .textAlign(TextAlign.Center)
          .width('100%')
          .margin({ top: Theme.SPACE_MD, bottom: Theme.SPACE_SM })

        // 副标题
        Text('了解星钥塔罗每个板块的用法和设计初衷')
          .fontSize(Theme.FONT_BODY)
          .fontColor(Theme.MOON_MUTED)
          .textAlign(TextAlign.Center)
          .width('100%')
          .margin({ bottom: Theme.SPACE_LG })

        // 板块列表
        Scroll() {
          Column() {
            ForEach(this.sections, (section: GuideSection, index: number) => {
              this.buildSectionCard(section.icon, section.title, section.body)
            }, (_section: GuideSection, index: number) => 'guide_section_' + index.toString())
          }
          .width('92%')
          .padding({ top: Theme.SPACE_SM, bottom: Theme.SAFE_BOTTOM })
        }
        .width('100%')
        .layoutWeight(1)
        .scrollBar(BarState.Off)
        .align(Alignment.Top)
      }
      .width('100%')
      .height('100%')
      .alignItems(HorizontalAlign.Center)
    }
    .width('100%')
    .height('100%')
    .alignContent(Alignment.TopStart)
  }
}
