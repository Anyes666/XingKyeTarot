/**
 * 星澜沉浸式陪伴首页 — 响应式比例布局（14 / 59 / 16 / 11）
 *
 * Stack 根容器：
 * ├─ Layer 1: 星澜背景图（Cover 满铺，opacity 0.82）
 * ├─ Layer 2: 渐变遮罩（顶暗→中透→底强暗）
 * └─ Layer 3: 主内容 Column（按 layoutWeight 比例分配）
 *     ├─ Header 品牌区      layoutWeight(14)  minHeight 108 / maxHeight 138
 *     ├─ DialogueArea 对话流  layoutWeight(59)  minHeight 360
 *     ├─ ActionArea 底部操作  layoutWeight(16)  minHeight 132 / maxHeight 172
 *     └─ BottomNav 底部导航   layoutWeight(11)  minHeight 78  / maxHeight 96
 *
 * 点击星澜背景/中间星澜按钮 → addNextXinglanQuote() 追加文案到 quoteList 末尾
 */
@Entry
@Component
struct HomePage {
  @State todayRecord: DivinationHistoryRecord | null = null;
  @State historyCount: number = 0;
  @State isDataLoaded: boolean = false;
  @State quoteIndex: number = 0;
  @State quoteList: string[] = [XINGLAN_QUOTES[0]];
  @State isXinglanResponding: boolean = false;
  @State isPlayingHomeGuide: boolean = false;
  @State hasScheduledHomeGuide: boolean = false;
  private scroller: Scroller = new Scroller();

  aboutToAppear(): void {
    this.prepareHomeGuide();
  }

  /**
   * 首次进入首页：加载数据 + 首次引导调度
   * - 数据加载（todayRecord / historyCount）保留原逻辑
   * - 首次未看过引导 → 延迟 600ms 后播放 2 句引导
   * - hasScheduledHomeGuide 防重复调度（本生命周期内不重置）
   */
  private async prepareHomeGuide(): Promise<void> {
    // 1. 先加载数据（原 aboutToAppear 逻辑）
    try {
      this.todayRecord = await HistoryStore.getTodayLatestRecord(getContext(this));
      this.historyCount = await HistoryStore.getCount(getContext(this));
    } catch (_err) {
      this.todayRecord = null;
      this.historyCount = 0;
    } finally {
      this.isDataLoaded = true;
    }

    // 2. 首次引导调度
    try {
      if (this.hasScheduledHomeGuide || this.isPlayingHomeGuide) {
        return;
      }
      const hasSeen: boolean = await PreferenceStore.getBoolean('hasSeenHomeGuide', false, getContext(this));
      if (!hasSeen) {
        this.hasScheduledHomeGuide = true;
        setTimeout(() => { this.playFirstLaunchGuide(); }, 600);
      }
    } catch (err) {
      hilog.error(0x0000, 'HomePage', 'prepareHomeGuide error: %{public}s', JSON.stringify(err));
    }
  }

  /**
   * 播放首次引导：2 句文案，间隔 HOME_GUIDE_DELAY_MS
   * 播放期间与点击星澜互斥（isPlayingHomeGuide）
   */
  private async playFirstLaunchGuide(): Promise<void> {
    this.isPlayingHomeGuide = true;
    try {
      const list1: string[] = [...this.quoteList, HOME_FIRST_GUIDE_LINE_1];
      this.quoteList = list1;
      this.scrollToBottom();
      await this.sleep(HOME_GUIDE_DELAY_MS);
      const list2: string[] = [...this.quoteList, HOME_FIRST_GUIDE_LINE_2];
      this.quoteList = list2;
      this.scrollToBottom();
      await PreferenceStore.putBoolean('hasSeenHomeGuide', true, getContext(this));
    } catch (err) {
      hilog.error(0x0000, 'HomePage', 'playFirstLaunchGuide error: %{public}s', JSON.stringify(err));
    } finally {
      this.isPlayingHomeGuide = false;
    }
  }

  /**
   * 追加下一条星澜文案到语句流末尾（循环）— 拟真时序版
   * 点击星澜 → 先追加"星澜安静地听着。" → 0.8~1.5s 延迟 → 移除临时句 → 追加正式文案
   * 回应期间重复点击不追加新文案（isXinglanResponding 防抖）
   */
  private async addNextXinglanQuote(): Promise<void> {
    if (this.isPlayingHomeGuide || this.isXinglanResponding) {
      return;
    }
    this.isXinglanResponding = true;
    try {
      // 1. 先追加临时倾听提示
      const listWithHint: string[] = [...this.quoteList, XINGLAN_LISTENING_HINT];
      this.quoteList = listWithHint;
      this.scrollToBottom();

      // 2. 延迟 800~1500ms（随机）
      const delay: number = 800 + Math.floor(Math.random() * 700);
      await this.sleep(delay);

      // 3. 保守移除临时句（仅当尾部确实等于 XINGLAN_LISTENING_HINT 时才删）
      const baseList: string[] = this.removeListeningHintFromTail();

      // 4. 追加正式文案（保留原 quoteIndex 顺序循环逻辑）
      this.quoteIndex = (this.quoteIndex + 1) % XINGLAN_QUOTES.length;
      const finalList: string[] = [...baseList, XINGLAN_QUOTES[this.quoteIndex]];
      this.quoteList = finalList;
      this.scrollToBottom();
    } catch (err) {
      hilog.error(0x0000, 'HomePage', 'addNextXinglanQuote error: %{public}s', JSON.stringify(err));
    } finally {
      this.isXinglanResponding = false;
    }
  }

  /**
   * 保守移除临时句：仅当尾部确实等于 XINGLAN_LISTENING_HINT 时才删，否则原样返回。
   * 避免与并发追加误删其他文案。
   */
  private removeListeningHintFromTail(): string[] {
    if (this.quoteList.length === 0) {
      return [];
    }
    if (this.quoteList[this.quoteList.length - 1] === XINGLAN_LISTENING_HINT) {
      return this.quoteList.slice(0, this.quoteList.length - 1);
    }
    return this.quoteList;
  }

  private sleep(ms: number): Promise<void> {
    return new Promise<void>((resolve: () => void) => {
      setTimeout(() => { resolve(); }, ms);
    });
  }

  private scrollToBottom(): void {
    try {
      this.scroller.scrollEdge(Edge.Bottom);
    } catch (_err) {
      // 滚动失败忽略
    }
  }

  private navigateToAskHeart(): void {
    try {
      const params: AskHeartRouteParams = { entryMode: 'NORMAL_SINGLE' };
      const options: router.RouterOptions = { url: Routes.ASK_HEART, params: params };
      router.pushUrl(options);
    } catch (_err) {
      // ignore
    }
  }

  private navigateToHistory(): void {
    try {
      const options: router.RouterOptions = { url: Routes.HISTORY };
      router.pushUrl(options);
    } catch (_err) {
      // ignore
    }
  }

  private formatTimestamp(ts: number): string {
    const d: Date = new Date(ts);
    const h: string = String(d.getHours()).padStart(2, '0');
    const m: string = String(d.getMinutes()).padStart(2, '0');
    return h + ':' + m;
  }

  build() {
    Stack() {
      // ═══════════════════════════════════════════
      // Layer 1: 星澜背景图
      // ═══════════════════════════════════════════
      Image($r('app.media.xinglan_home_main'))
        .objectFit(ImageFit.Cover)
        .width('100%')
        .height('100%')
        .translate({ x: 0, y: -80 })
        .opacity(0.82)
        .hitTestBehavior(HitTestMode.Transparent)

      // ═══════════════════════════════════════════
      // Layer 2: 渐变遮罩
      // ═══════════════════════════════════════════
      Column()
        .width('100%')
        .height('100%')
        .linearGradient({
          direction: GradientDirection.Bottom,
          colors: [
            ['#030716', 0.0],
            ['#030716', 0.08],
            ['rgba(4, 8, 23, 0.88)', 0.12],
            ['rgba(6, 10, 28, 0.50)', 0.22],
            ['rgba(6, 10, 28, 0.15)', 0.40],
            ['rgba(6, 10, 28, 0)', 0.58],
            ['rgba(15, 15, 35, 0)', 0.65],
            ['rgba(15, 15, 35, 0.78)', 0.87],
            ['#030716', 1.0]
          ]
        })
        .hitTestBehavior(HitTestMode.Transparent)

      // ═══════════════════════════════════════════
      // Layer 2.5: 沉浸光感 — 金色径向光晕（顶部品牌区附近，极低透明度）
      // ═══════════════════════════════════════════
      Column()
        .width('100%')
        .height('100%')
        .radialGradient({
          center: ['50%', '8%'],
          radius: '55%',
          colors: [
            ['rgba(202, 138, 4, 0.04)', 0.0],
            ['rgba(202, 138, 4, 0.025)', 0.25],
            ['rgba(202, 138, 4, 0.01)', 0.55],
            ['rgba(0, 0, 0, 0)', 1.0]
          ]
        })
        .hitTestBehavior(HitTestMode.Transparent)

      // ═══════════════════════════════════════════
      // Layer 3: 主内容 Column（比例布局 14/59/27）
      // 点击星澜背景追加文案
      // 底部导航已由 MainFramePage 统一管理，不再在此页面渲染
      // ═══════════════════════════════════════════
      Column() {
        // ── Header 品牌区 (14%, minHeight 108 / maxHeight 138) ──
        Stack() {
          Column() {
            Text(Constants.APP_NAME)
              .fontSize(Theme.FONT_HEADLINE)
              .fontColor(Theme.GOLD_LIGHT)
              .fontWeight(FontWeight.Bold)
              .textAlign(TextAlign.Center)

            Text('探索内心，点亮星光')
              .fontSize(Theme.FONT_BODY)
              .fontColor(Theme.MOON_MUTED)
              .textAlign(TextAlign.Center)
              .margin({ top: Theme.SPACE_SM })
          }
          .width('100%')
          .alignItems(HorizontalAlign.Center)
          .justifyContent(FlexAlign.Center)
          .margin({ top: 36 })

          // 右上角极淡设置入口（齿轮文字图标，opacity 0.5，弱于主操作）
          Text('⚙')
            .fontSize(20)
            .fontColor(Theme.MOON_MUTED)
            .opacity(0.5)
            .padding(12)
            .position({ x: '88%', y: Theme.SAFE_TOP + 4 })
            .onClick(() => {
              try {
                const options: router.RouterOptions = { url: Routes.SETTINGS };
                router.pushUrl(options);
              } catch (_err) {
                // ignore
              }
            })
        }
        .width('100%')
        .layoutWeight(14)
        .alignContent(Alignment.TopStart)
        .backgroundColor('#030716')
        .constraintSize({ minHeight: 108, maxHeight: 138 })

        // ── DialogueArea 对话流区 (59%, minHeight 360) ──
        Stack() {
          Scroll(this.scroller) {
            Column({ space: 10 }) {
              ForEach(this.quoteList, (quote: string, index: number) => {
                Text(quote)
                  .fontSize(16)
                  .fontColor(Theme.TEXT_PRIMARY_LIGHT)
                  .lineHeight(24)
                  .backgroundColor('rgba(27, 27, 48, 0.68)')
                  .borderRadius(16)
                  .padding({ left: 14, right: 14, top: 12, bottom: 12 })
                  .constraintSize({ maxWidth: '80%' })
                  .alignSelf(ItemAlign.Start)
              }, (quote: string, index: number) => index.toString() + '_' + quote.substring(0, 6))
            }
            .width('100%')
            .alignItems(HorizontalAlign.Start)
            .padding({ top: 36, bottom: 12 })
          }
          .width('100%')
          .height('100%')
          .scrollable(ScrollDirection.Vertical)
          .align(Alignment.Bottom)
          .scrollBar(BarState.Off)
          .hitTestBehavior(HitTestMode.Transparent)

          // 顶部渐隐遮罩
          Column()
            .width('100%')
            .height(36)
            .linearGradient({
              direction: GradientDirection.Bottom,
              colors: [
                ['#030716', 0.0],
                ['rgba(15, 15, 35, 0)', 1.0]
              ]
            })
            .hitTestBehavior(HitTestMode.Transparent)
            .position({ x: 0, y: 0 })
        }
        .width('100%')
        .layoutWeight(59)
        .constraintSize({ minHeight: 360 })
        .padding({ left: Theme.SPACE_SCREEN_PAD, right: Theme.SPACE_SCREEN_PAD })

        // ── ActionArea 底部操作区 (27%, minHeight 132 / maxHeight 240)
        //    原比例 16% + 底部导航 11%，底部导航已移除 ──
        Column() {
          Text('星澜会先接住你的情绪。')
            .fontSize(12)
            .fontColor(Theme.MOON_MUTED)
            .textAlign(TextAlign.Center)
            .width('100%')
            .margin({ bottom: 8 })

          Button('开始今日一占')
            .fontSize(18)
            .fontColor(Theme.BTN_DARK_TEXT)
            .fontWeight(FontWeight.Bold)
            .width('88%')
            .height(54)
            .backgroundColor(Theme.GOLD_MAIN)
            .borderRadius(28)
            .margin({ bottom: 10 })
            .onClick(() => { this.navigateToAskHeart(); })

          Text('查看最近记录')
            .fontSize(15)
            .fontColor(Theme.MOON_MUTED)
            .textAlign(TextAlign.Center)
            .width('100%')
            .margin({ bottom: 12 })
            .onClick(() => { this.navigateToHistory(); })

          Text(Constants.COMPLIANCE_FOOTER)
            .fontSize(11)
            .fontColor(Theme.MOON_MUTED)
            .textAlign(TextAlign.Center)
            .lineHeight(16)
            .width('100%')
            .padding({ left: Theme.SPACE_SCREEN_PAD, right: Theme.SPACE_SCREEN_PAD, bottom: 12 })
        }
        .width('100%')
        .layoutWeight(27)
        .alignItems(HorizontalAlign.Center)
        .justifyContent(FlexAlign.End)
        .constraintSize({ minHeight: 132, maxHeight: 240 })
        .padding({ bottom: 4 })
        .linearGradient({
          direction: GradientDirection.Bottom,
          colors: [
            ['rgba(15, 15, 35, 0)', 0.0],
            ['rgba(15, 15, 35, 0)', 0.15],
            ['rgba(15, 15, 35, 0.55)', 0.50],
            [Theme.BG_DEEP_INDIGO, 1.0]
          ]
        })
      }
      .width('100%')
      .height('100%')
      .onClick(() => {
        this.addNextXinglanQuote();
      })
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#030716')
    .alignContent(Alignment.TopStart)
  }
}

